{
  "name": "qcm-manager-edf-secab",
  "version": "63.0.0",
  "description": "QCM Manager EDF SECAB V63 - paramètres, random QCM, filtre réponses, rapport ISO pro.",
  "main": "main.js",
  "author": "SECAB",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis --x64 --publish never",
    "dist-portable": "electron-builder --win portable --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "fr.secab.qcmmanageredf",
    "productName": "QCM Manager EDF SECAB",
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "app/**/*",
      "build/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "QCM Manager EDF SECAB"
    }
  }
}